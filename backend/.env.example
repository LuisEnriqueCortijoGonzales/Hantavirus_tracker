# HantaTracker — variables de entorno opcionales para el backend RPi
# Copia a .env y ajusta. El script lee estas variables si existen.

# Path absoluto al repo (por defecto: dirname(backend/))
# REPO_ROOT=/home/pi/proyecto_tracker

# Identidad git para los commits del bot
GIT_USER_NAME=HantaTracker RPi Bot
GIT_USER_EMAIL=hantapi@noreply.local

# Si necesitas un proxy HTTP/HTTPS para salir a internet
# HTTPS_PROXY=http://192.168.1.1:8080
# HTTP_PROXY=http://192.168.1.1:8080
